{
  "name": "@stefansaladino/contractor-ui",
  "version": "2.0.0",
  "description": "Reusable contractor website design system",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./advanced": {
      "import": "./dist/advanced.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "src/index.d.ts"
  ],
  "types": "./src/index.d.ts",
  "sideEffects": [
    "./dist/styles.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "design-system",
    "contractor",
    "components",
    "reusable-ui",
    "esm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StefanSaladino/package-repo.git"
  },
  "bugs": {
    "url": "https://github.com/StefanSaladino/package-repo/issues"
  },
  "homepage": "https://github.com/StefanSaladino/package-repo#readme",
  "license": "MIT",
  "devDependencies": {
    "vite": "^8.0.14"
  }
}
